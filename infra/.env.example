# =============================================
# Assistente Virtual IA — Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA faça commit do arquivo .env com valores reais

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Evolution API ---
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE=assistente

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- n8n ---
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-strong-password
N8N_ENCRYPTION_KEY=change-me-32-char-encryption-key

# --- Google Calendar (Opcional) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5678/oauth2/callback

# --- Dashboard (Next.js) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000
